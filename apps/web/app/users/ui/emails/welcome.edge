<!doctype html>
<html lang="{{ i18n.locale }}">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ i18n.t('users.emails.welcome.page_title') }}</title>
  <style>
    body { margin: 0; padding: 0; background-color: #F7F3EE; -webkit-text-size-adjust: 100%; }
    .email-wrapper { max-width: 580px; margin: 24px auto; background-color: #F7F3EE; padding: 20px; }
    .email-card {
      background: #FAF7F2;
      border: 1px solid #E5E0D8;
      border-radius: 12px;
      padding: 48px 36px 40px;
      text-align: center;
      box-shadow: 0 2px 12px rgba(61, 54, 41, 0.06);
    }
    .title {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 26px;
      font-weight: 700;
      color: #3D3629;
      margin: 0 0 6px 0;
      letter-spacing: -0.3px;
    }
    .greeting {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 15px;
      color: #5E8A6F;
      font-weight: 600;
      margin: 0 0 20px 0;
    }
    .subtitle {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 15px;
      color: #6B6358;
      margin: 0 auto 32px auto;
      line-height: 1.7;
      max-width: 420px;
    }
    .button-wrapper { margin: 0 0 36px 0; }
    .button-wrapper a {
      display: inline-block;
      background: #5E8A6F;
      color: #FAF7F2;
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 14px;
      font-weight: 600;
      padding: 14px 40px;
      border-radius: 9999px;
      text-decoration: none;
      letter-spacing: 0.3px;
    }
    .divider {
      width: 48px;
      height: 2px;
      background: #E2D5B8;
      border: none;
      margin: 0 auto 16px auto;
    }
    .disclaimer {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 12px;
      line-height: 1.6;
      color: #B0A898;
      padding: 0 24px;
    }
    .footer {
      padding: 20px 20px 4px 20px;
      text-align: center;
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 11px;
      color: #B0A898;
      letter-spacing: 0.2px;
    }
  </style>
</head>
<body>
<div class="email-wrapper">
  <div class="email-card">
    <div class="title">
      {{ i18n.t('users.emails.welcome.title') }}
    </div>

    <div class="greeting">
      {{ i18n.t('users.emails.welcome.greeting', { full_name: username }) }}
    </div>

    <div class="subtitle">
      {{ i18n.t('users.emails.welcome.subtitle') }}
    </div>

    <div class="button-wrapper">
      <a href="{{ verificationUrl }}">{{ i18n.t('users.emails.welcome.action_btn') }}</a>
    </div>

    <hr class="divider" />

    <div class="disclaimer">
      {{ i18n.t('users.emails.welcome.disclaimer') }}
    </div>
  </div>

  <div class="footer">
    {{ i18n.t('users.emails.welcome.footer') }}
  </div>
</div>
</body>
</html>
