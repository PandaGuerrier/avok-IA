{
  "name": "@adonisjs/i18n",
  "description": "Internationalization for AdonisJS apps",
  "version": "2.2.3",
  "engines": {
    "node": ">=18.16.0"
  },
  "main": "build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "exports": {
    ".": "./build/index.js",
    "./factories": "./build/factories/main.js",
    "./services/main": "./build/services/i18n.js",
    "./i18n_provider": "./build/providers/i18n_provider.js",
    "./plugins/edge": "./build/src/plugins/edge.js",
    "./types": "./build/src/types.js"
  },
  "scripts": {
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "clean": "del-cli build",
    "typecheck": "tsc --noEmit",
    "copy:templates": "copyfiles --up=1 \"stubs/**/*.stub\" build",
    "precompile": "npm run lint && npm run clean",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "npm run compile",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "release": "release-it",
    "version": "npm run build",
    "quick:test": "node --import=ts-node-maintained/register/esm --enable-source-maps bin/test.ts"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/core": "^6.19.1",
    "@adonisjs/eslint-config": "^2.1.2",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^1.4.1",
    "@japa/assert": "^4.1.1",
    "@japa/file-system": "^2.3.2",
    "@japa/runner": "^4.4.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@swc/core": "^1.14.0",
    "@types/luxon": "^3.7.1",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^24.9.2",
    "@vinejs/vine": "^4.1.0",
    "c8": "^10.1.3",
    "copyfiles": "^2.4.1",
    "del-cli": "^7.0.0",
    "edge.js": "^6.3.0",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "release-it": "^19.0.5",
    "ts-node-maintained": "^10.9.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@poppinss/intl-formatter": "^3.0.5",
    "@poppinss/utils": "^6.10.1",
    "intl-messageformat": "^10.7.18",
    "luxon": "^3.7.2",
    "negotiator": "^1.0.0",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.6.0",
    "@vinejs/vine": "^2.0.0 || ^3.0.0 || ^4.0.0",
    "edge.js": "^6.0.2"
  },
  "peerDependenciesMeta": {
    "edge.js": {
      "optional": true
    },
    "@vinejs/vine": {
      "optional": true
    }
  },
  "author": "virk,adonisjs",
  "license": "MIT",
  "homepage": "https://github.com/adonisjs/i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adonisjs/i18n.git"
  },
  "bugs": {
    "url": "https://github.com/adonisjs/i18n/issues"
  },
  "keywords": [
    "intl",
    "localization",
    "translation",
    "i18n"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./services/i18n.ts",
      "./factories/main.ts",
      "./providers/i18n_provider.ts",
      "./src/types.ts",
      "./src/plugins/edge.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": true,
    "target": "esnext"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
